@startuml FR_realizace_cile_fr
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam backgroundColor #FEFEFE
left to right direction

title Realizace cílů funkčními požadavky – RQU008

package "Cíle" {
    usecase "C01 Informovat\nnovinkami" as C01
    usecase "C02 Správa novinek" as C02
    usecase "C03 Sledování\npřečtení" as C03
    usecase "C04 Referenční\ndokumenty" as C04
}

package "Funkční požadavky" {
    usecase "FR041 Panel novinek\nna nástěnce" as FR041
    usecase "FR042 Označení\npřečtené novinky" as FR042
    usecase "FR043 Administrace\nnovinek" as FR043
    usecase "FR044 Návody\na manuály" as FR044
}

FR041 ..> C01
FR042 ..> C03
FR043 ..> C02
FR044 ..> C04

@enduml
