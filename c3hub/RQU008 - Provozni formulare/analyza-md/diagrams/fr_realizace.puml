@startuml FR_realizace_cile_fr
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam backgroundColor #FEFEFE
left to right direction

title Realizace cílů funkčními požadavky – RQU008

package "Cíle" {
    usecase "C01 Informovat\nnovinkami" as C01
    usecase "C02 Správa novinek" as C02
    usecase "C03 Sledování\npřečtení" as C03
    usecase "C04 Referenční\ndokumenty" as C04
}

package "Funkční požadavky" {
    usecase "FR01 Panel novinek\nna nástěnce" as FR01
    usecase "FR02 Označení\npřečtené novinky" as FR02
    usecase "FR03 Administrace\nnovinek" as FR03
    usecase "FR04 Návody\na manuály" as FR04
}

FR01 ..> C01
FR02 ..> C03
FR03 ..> C02
FR04 ..> C04

@enduml
