    usecase "UC002 Označit novinku\njako přečtenou" as UC002
    usecase "UC003 Vytvořit novinku" as UC003
    usecase "UC004 Upravit novinku" as UC004
    usecase "UC005 Smazat novinku" as UC005
    usecase "UC006 Stáhnout\nnávod / manuál" as UC006
