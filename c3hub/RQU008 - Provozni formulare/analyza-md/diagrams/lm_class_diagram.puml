@startuml LM_class_diagram
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam classMinWidth 170
skinparam backgroundColor #FEFEFE
skinparam classBorderColor #1565C0
skinparam classBackgroundColor #E3F2FD
skinparam enumBorderColor #f57f17
skinparam enumBackgroundColor #fff9c4

title Logický model – Provozní formuláře a referenční dokumenty (RQU008)

class "Novinka" as L048 [[#lm-L048]] {
    identifikator_T : id
    lokaceNovinky_E : location
    text2000/CLOB_T : content
    typNovinky_E : type
    datumCas_T : createdAt
}

class "Přečtení novinky uživatelem" as L049 [[#lm-L049]] {
    identifikator_T : id
    anoNe_T : markedAsRead
}

class "Referenční dokument\n(statický zdroj)" as L050 [[#lm-L050]] #fff3e0 {
    text256_T : fileName
    typReferencnihoDokumentu_E : typ
    text50_T : jazyk
    anoNe_T : disabled
}

enum "typNovinky_E" as E036 [[#lm-E036]] {
    INFO
    WARNING
    ATTENTION
}

enum "lokaceNovinky_E" as E037 [[#lm-E037]] {
    dashboard
}

enum "typReferencnihoDokumentu_E" as E038 [[#lm-E038]] {
    Návod (zkrácený)
    Návod (kompletní)
    Výstup cvičení
    Školicí materiál
    Školicí video
}

class "(RQU001) Uživatelský kontext" as RQU001_USER #f3e5f5

L048 "1" -- "0..*" L049 : přečtení
L049 "0..*" -- "1" RQU001_USER : uživatel

L048 ..> E036 : type
L048 ..> E037 : location
L050 ..> E038 : typ

@enduml
