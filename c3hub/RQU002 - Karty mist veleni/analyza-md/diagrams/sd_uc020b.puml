@startuml SD_UC011b
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam backgroundColor #FEFEFE

title SD-UC020b – Přidat IP do MV

actor "Uživatel" as U
participant "<<Form area>>\nInformační toky\n[[#gui-G021]]" as Sec
participant "<<Form modal>>\nVýběr IP\n[[#gui-G033]]" as Sel
participant "<<Form modal>>\nInterakce s MV\n[[#gui-G031]]" as Dlg
participant "Server\nC3 HUB API" as S

U -> Sec : 1. Klikne + PŘIDAT PODLE IP
Sec -> Sel : 2. Otevře dialog výběru IP
Sel -> S : 2a. Načte IP z modelu SVŘ
S --> Sel : 2b. Seznam IP
U -> Sel : 3. Zvolí IP, potvrdí

Sel -> S : 4. POST /model/information-products/{ipId}\n:search-information-exchange-requirements
S --> Sel : 4a. Seznam souvisejících IER

alt Pro IP nebyly nalezeny IER (A-UC020b-1 / A-G033-1)
    Sel --> U : Info snackbar „Pro vybrané IP nebyly nalezeny žádné IER"
else IER nalezeny
    Sel -> Dlg : 5. Otevře Interakce s MV\n(isIer=true, showAlsoUnassigned=true, initExpandDataGridTree=true)
    Dlg -> Dlg : 5a. Render IER-rooted strom (IER -> TIN;\nfiltry BA/BP a IP předzapnuté)
    U -> Dlg : 6. Nastaví Req / Konzument / Poskytovatel (IER a TIN řádky)
    U -> Dlg : 7. Klikne ULOŽIT
    Dlg -> S : 7a. PATCH /command-posts/{id}/interactions
    S --> Dlg : 7b. HTTP 200
    Dlg --> U : 7c. Zavře dialog, aktualizuje detail
    alt Selže
        S --> Dlg : 7d. 4xx/5xx
        Dlg --> U : 7e. Snackbar „Došlo k neočekávané chybě"
    end
end

@enduml
