@startuml FR_realizace
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam backgroundColor #FEFEFE
skinparam rectangle {
    RoundCorner 20
    FontSize 11
}

title Realizace požadavků – Karty míst velení (RQU002)

rectangle "Cíle" {
    rectangle "C01\nEvidence MV" as C01 #FFFDE7
    rectangle "C02\nDetailní specifikace MV" as C02 #FFFDE7
    rectangle "C03\nHierarchie MV" as C03 #FFFDE7
    rectangle "C04\nExporty PDF/XLSX" as C04 #FFFDE7
}

rectangle "Funkční požadavky" {
    rectangle "FR006\nPřehled karet MV" as FR006 #C8E6C9
    rectangle "FR007\nDetail karty MV" as FR007 #C8E6C9
    rectangle "FR008\nEditace specifikace" as FR008 #C8E6C9
    rectangle "FR009\nStrukturu velení" as FR009 #C8E6C9
    rectangle "FR010\nFormulář schopností" as FR010 #C8E6C9
    rectangle "FR011\nIER/IP + FMN instrukce" as FR011 #C8E6C9
    rectangle "FR012\nStažení karty MV" as FR012 #C8E6C9
}

C01 <.. FR006 : «přispívá»
C01 <.. FR007 : «přispívá»
C02 <.. FR008 : «přispívá»
C02 <.. FR010 : «přispívá»
C02 <.. FR011 : «přispívá»
C03 <.. FR008 : «přispívá»
C03 <.. FR009 : «přispívá»
C04 <.. FR012 : «přispívá»

@enduml
