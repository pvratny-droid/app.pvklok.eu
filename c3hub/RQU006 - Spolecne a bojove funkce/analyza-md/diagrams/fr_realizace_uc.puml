@startuml FR_realizace_fr_uc
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam backgroundColor #FEFEFE
skinparam rectangle {
    RoundCorner 20
    FontSize 11
}

left to right direction

title Realizace požadavků – FR a UC

' === KONVENCE ===
' - Funkční požadavky: rectangle s barvou #C8E6C9 (zelená)
' - Use Cases: usecase s barvou #E3F2FD (modrá), seskupené do logických skupin
' - Vazby: čárkovaná šipka «realizuje»
' - Tento diagram zobrazuje jen FR→UC, první soubor (fr_realizace.puml) zobrazuje Cíle→FR

rectangle "Funkční požadavky" {
    rectangle "FR035\nPopis FR 1" as FR035 #C8E6C9
    rectangle "FR036\nPopis FR 2" as FR036 #C8E6C9
    ' DOPLNIT: Další FR
}

rectangle "UC – Skupina 1" {
    usecase "UC050\nNázev UC" as UC050 #E3F2FD
    ' DOPLNIT: Další UC
}

rectangle "UC – Skupina 2" {
    usecase "UC051\nNázev UC" as UC051 #E3F2FD
    ' DOPLNIT: Další UC
}

FR035 <.. UC050 : «realizuje»
FR036 <.. UC051 : «realizuje»

@enduml
