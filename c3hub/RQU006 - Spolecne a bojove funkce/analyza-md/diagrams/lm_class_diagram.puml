@startuml LM_class_diagram
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam classMinWidth 170
skinparam backgroundColor #FEFEFE
skinparam classBorderColor #1565C0
skinparam classBackgroundColor #E3F2FD
skinparam enumBorderColor #f57f17
skinparam enumBackgroundColor #fff9c4

title Logický model – Společné a bojové funkce + PI (RQU006)

class "Společná funkce" as L042 [[#lm-L042]] {
    cisloCele_T : id
    text256_T : cz
    text256_T : en
}

class "Bojová funkce" as L043 [[#lm-L043]] {
    cisloCele_T : id
    text256_T : cz
    text256_T : en
}

class "Vazba funkce na PI\n(business konstrukce)" as L044 [[#lm-L044]] #fff3e0 {
    identifikator_T : id
}

enum "spolecnaFunkce_E\n(8 hodnot)" as E035 [[#lm-E035]] {
    manévr
    palby
    velení a řízení
    zpravodajství
    informační činnost
    udržitelnost
    ochrana sil
    civilně-vojenská spolupráce
}

enum "bojovaFunkce_E\n(6 hodnot)" as E009 [[#lm-E009]] {
    mission command
    přesun a manévr
    zpravodajské zabezpečení
    palby
    udržování činnosti
    ochrana sil
}

class "(RQU004) Procedurální instrukce" as RQU004_PI #f3e5f5
class "(RQU002) Specifikace MV" as RQU002_SPEC #f3e5f5

L042 "1" -- "0..*" L044 : klasifikace
L043 "1" -- "0..*" L044 : klasifikace
L044 "0..*" -- "1" RQU004_PI : proceduralníInstrukce

L042 ..> E035
L043 ..> E009

L042 "0..*" -- "0..*" RQU002_SPEC : jointFunctions
L043 "0..*" -- "0..*" RQU002_SPEC : combatFunctions

@enduml
