@startuml SD_UC009
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam backgroundColor #FEFEFE

title SD-UC009 – Spravovat C2 vazby

actor "Uživatel" as U
participant "<<Form area>>\nC2Panel\n[[#gui-G007]]" as P
participant "<<Form modal>>\nC2VazbaVytvoření\n[[#gui-G012]]" as C
participant "Server\nC3 HUB API" as S

note over P : Detail mise, záložka Velení a řízení,\nzvolené MV pohledu
P -> S : 1. findAllC2Relationships(missionId)
S --> P : 2. C2RelationshipDto[]
P --> U : 3. Dva gridy: Nadřízená MV / Podřízená MV

alt Přidat vazbu
    U -> P : 4a. Klikne + nad gridem
    P -> C : 5a. Otevře dialog (směr dle gridu)
    U -> C : 6a. Zvolí protější MV (multi) a Typ vazby
    U -> C : 7a. Klikne VYTVOŘIT
    C -> S : 8a. POST C2 vazba – jedna na každé MV
else Smazat vazbu
    U -> P : 4b. Řádková akce Smazat + potvrzení
    P -> S : 5b. DELETE C2 vazba
end
S --> P : 9. 200 + invalidate

@enduml
