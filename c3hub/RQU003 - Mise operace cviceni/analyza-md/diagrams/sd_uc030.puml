@startuml SD_UC008
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam backgroundColor #FEFEFE

title SD-UC030 – Plánovat interakce mise

actor "Uživatel" as U
participant "<<Form grid area>>\nPlanningGrid\n[[#gui-G044]]" as G
participant "<<Form modal>>\nVýběrIER\n[[#gui-G032]]" as I
participant "<<Form modal>>\nKonfiguraceInterakcíMV\n[[#gui-G054]]" as K
participant "Server\nC3 HUB API" as S

note over G : Detail mise, záložka Interakce,\nzvolené MV pohledu
U -> G : 1. Klikne Přidat IER (toolbar)
G -> I : 2. Otevře dialog Výběr IER
U -> I : 3. Vybere IER, potvrdí PŘIDAT
I --> G : 4. IER jako kořenové uzly stromu
U -> G : 5. Na IER uzlu zvolí Přidat interakce MV
G -> K : 6. Otevře dialog Konfigurace interakcí MV
U -> K : 7. Zvolí cílové MV, zaškrtá role + PACE u TIN
U -> K : 8. Klikne ULOŽIT
K --> G : 9. Konfigurace interakcí
G -> S : 10. Diff – POST přibylých,\nDELETE odebraných interakcí
S --> G : 11. 200

alt Smazat interakce (IER nebo MV uzel)
    U -> G : 12a. Řádková akce Smazat + potvrzení
    G -> S : 13a. DELETE /missions/{id}/interactions/{id}
end

@enduml
