@startuml LM_class_diagram
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam classMinWidth 170
skinparam backgroundColor #FEFEFE
skinparam classBorderColor #1565C0
skinparam classBackgroundColor #E3F2FD
skinparam enumBorderColor #f57f17
skinparam enumBackgroundColor #fff9c4

title Logický model – Mise, operace, cvičení (RQU003)

class "Mise" as L015 [[#lm-L015]] {
    identifikator_T : id
    text256_T : name
    text2000/CLOB_T : description
    anoNe_T : invalidated
    text256_T : invalidatedBy
    datumCas_T : invalidatedAt
    text256_T : restoredBy
    datumCas_T : restoredAt
}

class "Druh mise" as L016 [[#lm-L016]] {
    identifikator_T : id
    text256_T : name
}

class "Interakce mise" as L017 [[#lm-L017]] {
    identifikator_T : id
    operacniTempo_E : pace
}

class "Velitelská vazba C2" as L018 [[#lm-L018]] {
    identifikator_T : id
    typC2Vazby_E : type
}

class "Rozložení grafu mise" as L019 [[#lm-L019]] {
    identifikator_T : id
    komplex_C : nodePositions
}

class "Export mise\n(navrhované)" as L020 [[#lm-L020]] #fff3e0 {
    identifikator_T : id
    text50_T : typ
    variantaReportu_E : varianta
    klasifikace_E : klasifikace
    text50_T : jazyk
    datumCas_T : datumGenerovani
}

enum "operacniTempo_E" as E024 [[#lm-E024]] {
    PRIMARY
    ALTERNATE
    CONTINGENCY
    EMERGENCY
}

enum "typC2Vazby_E" as E025 [[#lm-E025]] {
    FULLCOM
    OPCOM
    OPCON
    TACOM
    TACON
    ADCON
    LOGCON
}

enum "variantaReportu_E" as E026 [[#lm-E026]] {
    BASIC
    COMPLETE
}

enum "klasifikace_E" as E027 [[#lm-E027]] {
    OFFICIAL
    RESTRICTED
}

class "(RQU002) Místo velení" as RQU002_CP #f3e5f5
class "(RQU004) IER" as RQU004_IER #f3e5f5
class "(RQU004) TIN" as RQU004_TIN #f3e5f5

' Kompozice z Mise
L015 "1" *-- "0..*" L017 : *(kompozice)
L015 "1" *-- "0..*" L018 : *(kompozice)
L015 "1" *-- "0..1" L019 : *(kompozice)
L015 "1" *-- "0..*" L020 : *(kompozice)

' Mise -> druh mise + vlastnické MV
L015 "0..*" -- "1..*" L016 : missionTypeIds
L015 "0..*" -- "1" RQU002_CP : missionOwner

' Interakce mise
L017 "0..*" -- "1" RQU002_CP : sourceCommandPost
L017 "0..*" -- "1" RQU002_CP : targetCommandPost
L017 ..> RQU004_IER : ier
L017 ..> RQU004_TIN : tin
L017 ..> E024 : pace

' C2 vazby
L018 "0..*" -- "1" RQU002_CP : superordinate
L018 "0..*" -- "1" RQU002_CP : subordinate
L018 ..> E025 : type

' Export
L020 ..> E026 : varianta
L020 ..> E027 : klasifikace

@enduml
