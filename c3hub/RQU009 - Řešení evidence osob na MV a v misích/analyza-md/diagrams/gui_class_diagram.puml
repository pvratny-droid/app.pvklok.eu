@startuml GUI_class_diagram
skinparam classAttributeIconSize 0
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam classMinWidth 160
skinparam backgroundColor #FEFEFE
skinparam class {
  BackgroundColor #E0F2F1
  BorderColor #00695c
}

title GUI model – Řešení evidence osob na MV a v misích (RQU009)\nchystaný požadavek (návrh)

class "<<Form>>\nSeznamOsob" as G001 [[#gui-G001]] {
    H HText : Nadpis
    E EText : searchQuery
    E EGrid : Tabulka osob
    --
    + PřidatOsobu()
    + Vyhledat()
}

class "<<Form grid area>>\nTabulkaOsob" as G002 [[#gui-G002]] #e8f5e9 {
    R RAkce : Akce
    R RText : celeJmeno
    R RText : hodnost
    R RText : osobniCislo
    --
    + UpravitOsobu()
    + ObsaditPozici()
    + ZapojitDoMise()
}

class "<<Form modal>>\nDetailOsoby" as G003 [[#gui-G003]] #fff3e0 {
    H HText : Nadpis
    E EText : **celeJmeno**
    E EText : hodnost
    E EText : osobniCislo
    E EText : login
    --
    + Uložit()
    + Zrušit()
}

class "<<Form modal>>\nObsazeníPozice" as G004 [[#gui-G004]] #fff3e0 {
    H HText : Nadpis
    E ELOV : **osoba**
    R RText : pozice
    E EDatumCas : platnostOd
    E EDatumCas : platnostDo
    --
    + Uložit()
    + Zrušit()
}

class "<<Form modal>>\nZapojeníDoMise" as G005 [[#gui-G005]] #fff3e0 {
    H HText : Nadpis
    E ELOV : **osoba**
    R RText : mise
    E EText : roleVMisi
    E EDatumCas : platnostOd
    E EDatumCas : platnostDo
    --
    + Uložit()
    + Zrušit()
}

class "(RQU002) Pozice na MV" as RQU002_POS #f3e5f5
class "(RQU003) Mise" as RQU003_MISE #f3e5f5

G001 *-- G002 : obsahuje
G001 ..> G003 : opens
G002 ..> G003 : opens
G002 ..> G004 : opens
G002 ..> G005 : opens

G004 ..> RQU002_POS : kontext
G005 ..> RQU003_MISE : kontext

@enduml
