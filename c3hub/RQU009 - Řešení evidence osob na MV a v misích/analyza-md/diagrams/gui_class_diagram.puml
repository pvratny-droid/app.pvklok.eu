    E EText : **celeJmeno**
    E EText : hodnost
    E EText : osobniCislo
    E EText : login
    --
    + Uložit()
    + Zrušit()
}

class "<<Form modal>>\nObsazeníPozice" as G093 [[#gui-G093]] #fff3e0 {
    H HText : Nadpis
    E ELOV : **osoba**
    R RText : pozice
    E EDatumCas : platnostOd
    E EDatumCas : platnostDo
    --
    + Uložit()
    + Zrušit()
}

class "<<Form modal>>\nZapojeníDoMise" as G094 [[#gui-G094]] #fff3e0 {
    H HText : Nadpis
    E ELOV : **osoba**
    R RText : mise
    E EText : roleVMisi
