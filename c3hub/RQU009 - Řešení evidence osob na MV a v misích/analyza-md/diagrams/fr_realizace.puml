@startuml FR_realizace_cile_fr
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam backgroundColor #FEFEFE
left to right direction

title Realizace cílů funkčními požadavky – RQU009

package "Cíle" {
    usecase "C01 Doménová\nentita Osoba" as C01
    usecase "C02 Obsazení pozic\nna MV" as C02
    usecase "C03 Zapojení osob\ndo misí" as C03
    usecase "C04 Zpětná\nkompatibilita" as C04
}

package "Funkční požadavky" {
    usecase "FR045 Evidence osob" as FR045
    usecase "FR046 Obsazení pozic\nna MV osobami" as FR046
    usecase "FR047 Zapojení osob\ndo misí" as FR047
    usecase "FR048 Zpětná kompatibilita\ns legacy textem" as FR048
}

FR045 ..> C01
FR046 ..> C02
FR047 ..> C03
FR048 ..> C04

@enduml
