@startuml FR_realizace_cile_fr
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam backgroundColor #FEFEFE
left to right direction

title Realizace cílů funkčními požadavky – RQU001

package "Cíle" {
    usecase "C01 Vstupní bod\n(nástěnka)" as C01
    usecase "C02 Uživatelský\nkontext" as C02
    usecase "C03 Notifikace\nschvalování" as C03
    usecase "C04 Novinky a\nintegrace" as C04
}

package "Funkční požadavky" {
    usecase "FR01 Nástěnka\ns rozcestníkem" as FR01
    usecase "FR02 Hlavní menu\na uživ. kontext" as FR02
    usecase "FR03 Notifikace\npatch requestů" as FR03
    usecase "FR04 Panel novinek" as FR04
    usecase "FR05 Integrace\ns externími systémy" as FR05
}

FR01 ..> C01
FR02 ..> C02
FR03 ..> C03
FR04 ..> C04
FR05 ..> C04

@enduml
