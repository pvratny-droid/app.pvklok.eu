@startuml FR_realizace_cile_fr
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam backgroundColor #FEFEFE
left to right direction

title Realizace cílů funkčními požadavky – RQU001

package "Cíle" {
    usecase "C01 Vstupní bod\n(nástěnka)" as C01
    usecase "C02 Uživatelský\nkontext" as C02
    usecase "C03 Notifikace\nschvalování" as C03
    usecase "C04 Novinky a\nintegrace" as C04
}

package "Funkční požadavky" {
    usecase "FR001 Nástěnka\ns rozcestníkem" as FR001
    usecase "FR002 Hlavní menu\na uživ. kontext" as FR002
    usecase "FR003 Notifikace\npatch requestů" as FR003
    usecase "FR004 Panel novinek" as FR004
    usecase "FR005 Integrace\ns externími systémy" as FR005
}

FR001 ..> C01
FR002 ..> C02
FR003 ..> C03
FR004 ..> C04
FR005 ..> C04

@enduml
