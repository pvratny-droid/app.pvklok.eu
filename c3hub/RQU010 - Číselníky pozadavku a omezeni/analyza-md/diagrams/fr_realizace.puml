@startuml FR_realizace_cile_fr
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam backgroundColor #FEFEFE
left to right direction

title Realizace cílů funkčními požadavky – RQU010

package "Cíle" {
    usecase "C01 Sjednocení podnikových\nčíselníků pod Element framework" as C01
    usecase "C02 Lifecycle aktivní/zrušená\nbez ztráty historie" as C02
    usecase "C03 Auditovatelnost\n(přehled MV užívajících položku)" as C03
}

package "Funkční požadavky" {
    usecase "FR01 Stereotypy REQ/CONSTR\n+ panel Číselníky v Modelu SVŘ" as FR01
    usecase "FR02 Lifecycle položky\n(aktivní/zrušená)" as FR02
    usecase "FR03 Zrušení s detekcí použití\n+ nabídka trvalého výmazu" as FR03
    usecase "FR04 Vyhledávání + toggle\n„Zobrazit i zrušené"" as FR04
    usecase "FR05 Zobrazení MV\nužívajících položku" as FR05
}

FR01 ..> C01
FR02 ..> C02
FR03 ..> C02
FR04 ..> C01
FR04 ..> C02
FR05 ..> C03

@enduml
