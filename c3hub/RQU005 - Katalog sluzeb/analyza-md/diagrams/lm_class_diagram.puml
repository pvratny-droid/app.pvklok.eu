class "CIS Aplikace\n<<CISAPP>>" as L004 [[#lm-L004]]
class "CIS Zařízení\n<<CISDEV>>" as L005 [[#lm-L005]]

enum "kategorieKataloguSlužeb_E" as E001 [[#lm-E001]] {
    SRV (read-only)
    APL (read-only)
    CISAPP (editovatelná)
    CISDEV (editovatelná)
}

class "(RQU004) Element modelu" as RQU004_L001 #f3e5f5
class "(RQU004) TIN" as RQU004_TIN #f3e5f5

L001 <|-- L002
