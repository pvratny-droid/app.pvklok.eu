@startuml FR_realizace_cile_fr
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam backgroundColor #FEFEFE
left to right direction

title Realizace cílů funkčními požadavky – RQU005

package "Cíle" {
    usecase "C01 Katalog CIS služeb\nve 4 kategoriích" as C01
    usecase "C02 Prohlížení a\núdržba katalogu" as C02
    usecase "C03 Odlišení read-only\na editovatelných" as C03
}

package "Funkční požadavky" {
    usecase "FR01 Přehled\nkatalogu služeb" as FR01
    usecase "FR02 Detail kategorie\na vyhledávání" as FR02
    usecase "FR03 Vytvoření / editace\nCIS prvku" as FR03
    usecase "FR04 Read-only\nzobrazení služeb" as FR04
}

FR01 ..> C01
FR02 ..> C02
FR03 ..> C02
FR03 ..> C03
FR04 ..> C03

@enduml
