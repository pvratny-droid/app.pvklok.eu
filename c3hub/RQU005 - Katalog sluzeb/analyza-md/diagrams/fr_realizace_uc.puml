@startuml FR_realizace_fr_uc
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam backgroundColor #FEFEFE
skinparam rectangle {
    RoundCorner 20
    FontSize 11
}

left to right direction

title Realizace požadavků – FR a UC

' === KONVENCE ===
' - Funkční požadavky: rectangle s barvou #C8E6C9 (zelená)
' - Use Cases: usecase s barvou #E3F2FD (modrá), seskupené do logických skupin
' - Vazby: čárkovaná šipka «realizuje»
' - Tento diagram zobrazuje jen FR→UC, první soubor (fr_realizace.puml) zobrazuje Cíle→FR

rectangle "Funkční požadavky" {
    rectangle "FR031\nPopis FR 1" as FR031 #C8E6C9
    rectangle "FR032\nPopis FR 2" as FR032 #C8E6C9
    ' DOPLNIT: Další FR
}

rectangle "UC – Skupina 1" {
    usecase "UC047\nNázev UC" as UC047 #E3F2FD
    ' DOPLNIT: Další UC
}

rectangle "UC – Skupina 2" {
    usecase "UC048\nNázev UC" as UC048 #E3F2FD
    ' DOPLNIT: Další UC
}

FR031 <.. UC047 : «realizuje»
FR032 <.. UC048 : «realizuje»

@enduml
