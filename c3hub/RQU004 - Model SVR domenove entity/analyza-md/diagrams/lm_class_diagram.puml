@startuml LM_class_diagram
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam classMinWidth 160
skinparam backgroundColor #FEFEFE
skinparam classBorderColor #1565C0
skinparam classBackgroundColor #E3F2FD
skinparam enumBorderColor #f57f17
skinparam enumBackgroundColor #fff9c4

title Logický model – Model SVŘ doménové entity (RQU004)

abstract class "Element modelu" as L001 [[#lm-L001]] {
    identifikator_T : id
    archiMateTyp_E : type
    stereotyp_E : stereotype
    kod_T : s5636Identifier
    text256_T : name
    text256_T : nameCz
    text2000/CLOB_T : description
    text2000/CLOB_T : descriptionCz
    stavPřekladu_E : translationStatus
    text256_T : image
    kódZemě_E : countryCode
}

class "MCA Schopnost\n<<CAP>>" as L002 [[#lm-L002]]
class "IER\n<<IER>>" as L003 [[#lm-L003]]
class "IP\n<<IP>>" as L004 [[#lm-L004]]
class "TIN\n<<TIN>>" as L005 [[#lm-L005]]
class "Role\n<<ROLE>>" as L006 [[#lm-L006]]
class "Pozice\n<<POSITION>>" as L007 [[#lm-L007]]
class "Aktivita\n<<BA>>" as L008 [[#lm-L008]]
class "Proces\n<<BP>>" as L009 [[#lm-L009]]
class "Procedurální instrukce\n<<PI>>" as L010 [[#lm-L010]]
class "Organizace\n<<ORG>>" as L011 [[#lm-L011]]
class "Org. jednotka\n<<OU>>" as L012 [[#lm-L012]]
class "Místo velení\n<<CP>>" as L013 [[#lm-L013]] #f3e5f5
class "IER Grouping\n<<IER_GROUPING>>" as L014 [[#lm-L014]]
class "Infrastrukturní služba\n<<SRV>>\n(read-only)" as L015 [[#lm-L015]] #f3e5f5
class "Aplikační služba\n<<APL>>\n(read-only)" as L016 [[#lm-L016]] #f3e5f5
class "CIS Aplikace\n<<CISAPP>>" as L017 [[#lm-L017]]
class "CIS Zařízení\n<<CISDEV>>" as L018 [[#lm-L018]]

class "Vztah" as L019 [[#lm-L019]] {
    identifikator_T : id
    typVztahu_E : type
    text/JSON_T : properties
}

class "Patch Request" as L020 [[#lm-L020]] {
    identifikator_T : id
    komplex_C : requestContent
    komplex_C : approveContent
    text256_T : requestedBy
    datumCas_T : requestedAt
    text256_T : closedBy
    datumCas_T : closedAt
    stavPatchRequestu_E : state
}

class "Subkategorie MCA" as L021 [[#lm-L021]] {
    identifikator_T : id
    text256_T : name
}

enum "stereotyp_E\n(17 hodnot)" as E001 [[#lm-E001]] {
    CAP / IER / IP / TIN / ROLE
    POSITION / BA / BP / PI / ORG / OU
    CP / IER_GROUPING / SRV / APL
    CISAPP / CISDEV
}

enum "archiMateTyp_E\n(15 hodnot)" as E002 [[#lm-E002]] {
    APPLICATION_COMPONENT / SERVICE
    BUSINESS_ACTOR / INTERACTION / OBJECT
    BUSINESS_PROCESS / ROLE
    CAPABILITY / COURSE_OF_ACTION
    DELIVERABLE / DEVICE / FACILITY
    GROUPING / TECHNOLOGY_INTERACTION / SERVICE
}

enum "typVztahu_E\n(9 hodnot)" as E003 [[#lm-E003]] {
    ACCESS
    AGGREGATION
    ASSIGNMENT
    ASSOCIATION
    COMPOSITION
    FLOW
    REALIZATION
    SERVING
    TRIGGERING
}

enum "stavPřekladu_E" as E004 [[#lm-E004]] {
    AI_TRANSLATED
    UPDATED
    APPROVED
}

enum "stavPatchRequestu_E" as E005 [[#lm-E005]] {
    REQUESTED
    APPROVED
    REJECTED
}

' Dědičnost / specializace
L001 <|-- L002
L001 <|-- L003
L001 <|-- L004
L001 <|-- L005
L001 <|-- L006
L001 <|-- L007
L001 <|-- L008
L001 <|-- L009
L001 <|-- L010
L001 <|-- L011
L001 <|-- L012
L001 <|-- L013
L001 <|-- L014
L001 <|-- L015
L001 <|-- L016
L001 <|-- L017
L001 <|-- L018

' Vztahy mezi prvky modelu
L019 "0..*" -- "1" L001 : sourceElement
L019 "0..*" -- "1" L001 : targetElement
L019 ..> E003 : type

' Patch Request
L020 "*" -- "1" L001 : referentialElementId
L020 "0..*" -- "*" L019 : toAdd / toDelete
L020 ..> E005 : state

' MCA subkategorie
L002 "1" *-- "0..*" L021

' Doménové vazby napříč stereotypy
L008 "0..*" --o "0..*" L009 : composition
L011 "1" o-- "0..*" L012
L017 "0..*" -- "0..*" L005 : provádí
L018 "0..*" -- "0..*" L005 : provádí
L005 "0..*" -- "0..*" L003 : realizace
L010 "0..*" -- "0..*" L003

' Číselníky
L001 ..> E001 : stereotype
L001 ..> E002 : type
L001 ..> E004 : translationStatus

@enduml
