L021 <|-- L032
L021 <|-- L003
L021 <|-- L033
L021 <|-- L034
L021 <|-- L035
L021 <|-- L036
L021 <|-- L037

' Vztahy mezi prvky modelu
L038 "0..*" -- "1" L021 : sourceElement
L038 "0..*" -- "1" L021 : targetElement
L038 ..> E030 : type

' Patch Request
L039 "*" -- "1" L021 : referentialElementId
L039 "0..*" -- "*" L038 : toAdd / toDelete
L039 ..> E032 : state

' MCA subkategorie
L022 "1" *-- "0..*" L040

' Doménové vazby napříč stereotypy
L028 "0..*" --o "0..*" L029 : composition
L031 "1" o-- "0..*" L032
L036 "0..*" -- "0..*" L025 : provádí
L037 "0..*" -- "0..*" L025 : provádí
L025 "0..*" -- "0..*" L023 : realizace
L030 "0..*" -- "0..*" L023

' Číselníky
L021 ..> E028 : stereotype
L021 ..> E029 : type
L021 ..> E031 : translationStatus

@enduml
