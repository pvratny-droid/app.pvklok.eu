@startuml LM_class_diagram
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 11
skinparam classMinWidth 160
skinparam backgroundColor #FEFEFE
skinparam classBorderColor #1565C0
skinparam classBackgroundColor #E3F2FD
skinparam enumBorderColor #f57f17
skinparam enumBackgroundColor #fff9c4

title Logický model – Model SVŘ doménové entity (RQU004)

abstract class "Element modelu" as L021 [[#lm-L021]] {
    identifikator_T : id
    archiMateTyp_E : type
    stereotyp_E : stereotype
    kod_T : s5636Identifier
    text256_T : name
    text256_T : nameCz
    text2000/CLOB_T : description
    text2000/CLOB_T : descriptionCz
    stavPřekladu_E : translationStatus
    text256_T : image
    kódZemě_E : countryCode
}

class "MCA Schopnost\n<<CAP>>" as L022 [[#lm-L022]]
class "IER\n<<IER>>" as L023 [[#lm-L023]]
class "IP\n<<IP>>" as L024 [[#lm-L024]]
class "TIN\n<<TIN>>" as L025 [[#lm-L025]]
class "Role\n<<ROLE>>" as L026 [[#lm-L026]]
class "Pozice\n<<POSITION>>" as L027 [[#lm-L027]]
class "Aktivita\n<<BA>>" as L028 [[#lm-L028]]
class "Proces\n<<BP>>" as L029 [[#lm-L029]]
class "Procedurální instrukce\n<<PI>>" as L030 [[#lm-L030]]
class "Organizace\n<<ORG>>" as L031 [[#lm-L031]]
class "Org. jednotka\n<<OU>>" as L032 [[#lm-L032]]
class "Místo velení\n<<CP>>" as L003 [[#lm-L003]] #f3e5f5
class "IER Grouping\n<<IER_GROUPING>>" as L033 [[#lm-L033]]
class "Infrastrukturní služba\n<<SRV>>\n(read-only)" as L034 [[#lm-L034]] #f3e5f5
class "Aplikační služba\n<<APL>>\n(read-only)" as L035 [[#lm-L035]] #f3e5f5
class "CIS Aplikace\n<<CISAPP>>" as L036 [[#lm-L036]]
class "CIS Zařízení\n<<CISDEV>>" as L037 [[#lm-L037]]

class "Vztah" as L038 [[#lm-L038]] {
    identifikator_T : id
    typVztahu_E : type
    text/JSON_T : properties
}

class "Patch Request" as L039 [[#lm-L039]] {
    identifikator_T : id
    komplex_C : requestContent
    komplex_C : approveContent
    text256_T : requestedBy
    datumCas_T : requestedAt
    text256_T : closedBy
    datumCas_T : closedAt
    stavPatchRequestu_E : state
}

class "Subkategorie MCA" as L040 [[#lm-L040]] {
    identifikator_T : id
    text256_T : name
}

enum "stereotyp_E\n(17 hodnot)" as E028 [[#lm-E028]] {
    CAP / IER / IP / TIN / ROLE
    POSITION / BA / BP / PI / ORG / OU
    CP / IER_GROUPING / SRV / APL
    CISAPP / CISDEV
}

enum "archiMateTyp_E\n(15 hodnot)" as E029 [[#lm-E029]] {
    APPLICATION_COMPONENT / SERVICE
    BUSINESS_ACTOR / INTERACTION / OBJECT
    BUSINESS_PROCESS / ROLE
    CAPABILITY / COURSE_OF_ACTION
    DELIVERABLE / DEVICE / FACILITY
    GROUPING / TECHNOLOGY_INTERACTION / SERVICE
}

enum "typVztahu_E\n(9 hodnot)" as E030 [[#lm-E030]] {
    ACCESS
    AGGREGATION
    ASSIGNMENT
    ASSOCIATION
    COMPOSITION
    FLOW
    REALIZATION
    SERVING
    TRIGGERING
}

enum "stavPřekladu_E" as E031 [[#lm-E031]] {
    AI_TRANSLATED
    UPDATED
    APPROVED
}

enum "stavPatchRequestu_E" as E032 [[#lm-E032]] {
    REQUESTED
    APPROVED
    REJECTED
}

